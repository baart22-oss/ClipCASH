# ── ClipCASH Backend Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your GitHub Pages URL (no trailing slash) for testing.
# Update to your custom domain once it is configured.
# Example (GitHub Pages): https://your-username.github.io/ClipCASH
# Example (custom domain): https://clipcash.co.za
ALLOWED_ORIGIN=https://your-username.github.io

# ── JWT ───────────────────────────────────────────────────────────────────────
# Used to sign both user JWTs (7-day TTL) and admin JWTs (4-hour TTL).
# Generate a strong random value, e.g.: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# ── Admin Access ─────────────────────────────────────────────────────────────
# ADMIN_USERNAME – the username entered in the admin login form (default: admin).
# ADMIN_PASSWORD – the password entered in the admin login form.
#                  The frontend POSTs these to POST /api/admin/login and receives
#                  a short-lived JWT (stored in sessionStorage, never localStorage).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-secure-password

# ── Yoco Payments ─────────────────────────────────────────────────────────────
# Obtain these from your Yoco dashboard: https://dashboard.yoco.com
# YOCO_WEBHOOK_SECRET – used to verify HMAC-SHA256 webhook signatures.
# YOCO_SECRET_KEY     – used to create payment charges via the Yoco API.
YOCO_WEBHOOK_SECRET=
YOCO_SECRET_KEY=
